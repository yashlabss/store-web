# store-web — production defaults (committed). Next.js loads this in all environments.
#
# Local development: `.env.local` (gitignored) overrides BACKEND_URL to http://127.0.0.1:5000
# when you run `npm run dev` (see scripts/ensure-env-local.js).
#
# Hosting (Vercel, etc.): keep these production values, or override in the host UI.

NEXT_PUBLIC_APP_NAME=Mintln
# Leave empty so the browser uses same-origin /api/* and Next rewrites to BACKEND_URL (avoids CORS).
NEXT_PUBLIC_API_BASE_URL=
# Live API origin (no trailing slash). Rewrites /api/* at build and request time.
BACKEND_URL=https://api.mintln.com
NEXT_PUBLIC_STORE_BASE_URL=https://mintln.com
