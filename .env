# store-web — production defaults (committed). Next.js loads this in all environments.
#
# Local development: create .env.local (gitignored). It overrides these values.
# If .env.local is missing, npm run dev runs predev and creates it with localhost defaults.
#
# Do not deploy .env.local to production if it contains dev URLs.

NEXT_PUBLIC_APP_NAME=Mintlin
NEXT_PUBLIC_API_BASE_URL=https://api.mintlin.com
BACKEND_URL=https://api.mintlin.com
NEXT_PUBLIC_STORE_BASE_URL=https://www.mintlin.com

# Resend → Webhooks: use https://www.mintlin.com/api/webhooks/resend (avoid apex → www 308).
# Set the same Svix signing secret here as in Resend for POST verification before proxying to Express:
# RESEND_WEBHOOK_SECRET=whsec_...
