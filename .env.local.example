# Copy to `.env.local` in this folder (store-web/.env.local).
#
# Leave NEXT_PUBLIC_API_BASE_URL unset in local dev so the app calls `/api/...` on the same
# origin; Next.js rewrites proxy to the Express backend (see next.config.ts → BACKEND_URL).
#
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:5000

# Optional: if the backend is not on 5000, point the proxy at it:
# BACKEND_URL=http://127.0.0.1:5000
