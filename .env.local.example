# Copy to `.env.local` in this folder (store-web/.env.local).
#
# Leave NEXT_PUBLIC_API_BASE_URL unset in local dev so the app calls `/api/...` on the same
# origin; Next.js rewrites proxy to the Express backend (see next.config.ts → BACKEND_URL).
#
# NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:5001

# Optional: if the backend is not on 5001, point the proxy at it:
# BACKEND_URL=http://127.0.0.1:5001

# --- Google OAuth (Coaching → Google Meet “Connect”) ---
# Create credentials in Google Cloud Console: APIs & Services → Credentials → Create
# credentials → OAuth client ID → Application type: Web application.
# Authorized redirect URIs must include exactly:
#   http://localhost:3000/api/integrations/google/callback
# (Add your production URL + /api/integrations/google/callback when you deploy.)
# Enable Google Calendar API for the project. OAuth scopes used: calendar, calendar.events.
#
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
#
# Optional but recommended so redirect URIs match in dev vs prod:
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Booking confirmation email (Coaching Meet link) ---
# Without RESEND_API_KEY, Meet events still work; emails are skipped.
# Get an API key at https://resend.com — verify a sending domain or use Resend's
# onboarding sender for testing. Restart the dev server after changing env.
#
# RESEND_API_KEY=re_...
# BOOKING_FROM_EMAIL=noreply@yourdomain.com
